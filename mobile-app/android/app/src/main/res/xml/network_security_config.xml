<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Allow HTTP for development - allow all cleartext traffic in development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain> <!-- Android emulator localhost -->
        <domain includeSubdomains="true">192.168.1.213</domain>
        <domain includeSubdomains="true">192.168.*.*</domain> <!-- Allow any local network IP -->
    </domain-config>
    <!-- Allow all HTTP traffic for development (be careful in production) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" /> <!-- For self-signed certificates -->
        </trust-anchors>
    </base-config>
</network-security-config>